{
  "name": "Agent Development Environment",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "IMAGE_REGISTRY": "${localEnv:IMAGE_REGISTRY:local}",
      "PROD_BASE_IMAGE": "${localEnv:PROD_BASE_IMAGE:local/web-deploy-base:latest}"
    }
  },
  "remoteUser": "developer",
  "forwardPorts": [
    11434
  ],
  "runArgs": [
    "--add-host=host.docker.internal:host-gateway"
  ],
  "containerEnv": {
    "BRAVE_API_KEY": "${localEnv:BRAVE_API_KEY}"
  },
  "postCreateCommand": "bash ${containerWorkspaceFolder}/agent-dev-env/.devcontainer/base/configure.sh",
  "updateContentCommand": "bash ${containerWorkspaceFolder}/agent-dev-env/.devcontainer/base/configure.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "Continue.continue"
      ]
    }
  }
}